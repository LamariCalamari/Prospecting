# Streamlit Community Cloud secrets template.
#
# LOCAL USE: you don't need this file — use `.env` instead.
# DEPLOYED USE: copy the lines below into your app's Secrets manager on
#   Streamlit Community Cloud (App → ⋮ → Settings → Secrets), filling in values.
#   Do NOT commit a real secrets.toml — it is git-ignored.

COMPANIES_HOUSE_API_KEY = "your-companies-house-key"
APP_CONTACT_EMAIL = "you@example.com"

# Optional free deep-dive sources — leave out any you haven't set up.
FCA_API_EMAIL = ""
FCA_API_KEY = ""
CHARITY_COMMISSION_API_KEY = ""
OPENSANCTIONS_API_KEY = ""
