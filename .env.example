# Copy this file to `.env` and fill in your key. The .env file is git-ignored.
#
# Get a free Companies House API key:
#   1. Register at https://developer.company-information.service.gov.uk/
#   2. Create an application (type: "Live" REST API).
#   3. Copy the API key below.
COMPANIES_HOUSE_API_KEY=

# Optional: identify your app politely to Wikipedia / Google News / Wikidata.
# Put a real contact email here if you deploy this anywhere public.
APP_CONTACT_EMAIL=your-email@example.com

# ---------------------------------------------------------------------------
# OPTIONAL deep-dive sources. Each is free; leave blank to disable that source
# (the app will note it as "not configured" and simply skip it).
# Wikipedia, Wikidata, Google News and The Gazette need NO keys.
# ---------------------------------------------------------------------------

# FCA Financial Services Register — https://register.fca.org.uk/Developer/s/
#   Register, then use the email you signed up with + the API key you're issued.
FCA_API_EMAIL=
FCA_API_KEY=

# Charity Commission — https://api-portal.charitycommission.gov.uk/
#   Subscribe to the "Search" product to get a subscription key.
CHARITY_COMMISSION_API_KEY=

# OpenSanctions (PEP / sanctions screening) — https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=
